{
  "expo": {
    "name": "Deeply Fit",
    "slug": "deeply-fit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.deeplyfit.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan food with AI",
        "NSPhotoLibraryUsageDescription": "Used to select food photos"
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.deeplyfit.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select food photos"
        }
      ],
      "expo-status-bar",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "https://deeplyfit-backend.onrender.com",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}