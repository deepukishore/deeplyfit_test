{
  "expo": {
    "name": "Deeply Fit",
    "slug": "deeply-fit",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.deeplyfit.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan food with AI",
        "NSPhotoLibraryUsageDescription": "Used to select food photos"
      }
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f6f2ff"
      },
      "package": "com.deeplyfit.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select food photos"
        }
      ],
      "expo-status-bar",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "https://deeplyfit-backend.onrender.com",
      "eas": {
        "projectId": "49af3e5c-0ba4-45e2-af60-47ae2a86ab3e"
      }
    },
    "owner": "deepukishore17"
  }
}
